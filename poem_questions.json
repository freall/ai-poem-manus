[
  {
    "poemId": 1,
    "questions": [
      {
        "q": "这首诗的作者是谁？",
        "a": "张栻",
        "exp": "张栻是宋代著名诗人，这首诗表现了春天的到来。"
      },
      {
        "q": "诗中提到春天来临时，自然界会发生什么变化？",
        "a": "草木都能感受到春天的到来，眼前生机盎然",
        "exp": "诗人通过观察自然，感悟到春天给大自然带来的生机。"
      },
      {
        "q": "\"东风吹水绿参差\"中的\"东风\"代表什么？",
        "a": "春风",
        "exp": "东风是春风的象征，象征着春天的到来和生机。"
      }
    ]
  },
  {
    "poemId": 2,
    "questions": [
      {
        "q": "\"碧玉妆成一树高\"中的\"碧玉\"比喻什么？",
        "a": "柳树",
        "exp": "诗人用碧玉这样的珍贵宝石来比喻柳树的美丽。"
      },
      {
        "q": "\"万条垂下绿丝绦\"中的\"绿丝绦\"指的是什么？",
        "a": "柳条",
        "exp": "绿色的丝带般的柳条垂下来，形容柳树的优美。"
      },
      {
        "q": "这首诗最后两句想表达什么？",
        "a": "春风就像剪刀一样，剪出了细细的柳叶",
        "exp": "诗人用拟人化的手法，赋予春风生命力和创造力。"
      }
    ]
  },
  {
    "poemId": 3,
    "questions": [
      {
        "q": "\"好雨知时节\"中的\"知\"是什么意思？",
        "a": "了解、懂得",
        "exp": "诗人拟人化地说春雨了解时节，在恰当的时候下起。"
      },
      {
        "q": "\"润物细无声\"体现了春雨的什么特点？",
        "a": "无声而细致地滋润万物",
        "exp": "春雨默默地、细致地滋润着大地上的万物。"
      },
      {
        "q": "这首诗表达了诗人对春雨的什么感情？",
        "a": "赞美和感激",
        "exp": "诗人通过细致的描写，表达了对春雨的赞美。"
      }
    ]
  },
  {
    "poemId": 4,
    "questions": [
      {
        "q": "\"迟日江山丽\"中的\"迟日\"指的是什么？",
        "a": "春天日子变长了",
        "exp": "春天白天变长，太阳升起得晚，落下得也晚。"
      },
      {
        "q": "\"泥融飞燕子\"说明了什么？",
        "a": "春天泥土融化，燕子开始活动",
        "exp": "这是春天到来的一个重要标志。"
      },
      {
        "q": "这首诗用什么手法描写春天？",
        "a": "通过景物描写",
        "exp": "诗人通过描写春天的各种景象，表现春天的美丽。"
      }
    ]
  },
